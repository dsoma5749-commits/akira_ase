# --- Standard HKDF-SHA256 (RFC 5869) Key Derivation ---  
def _hkdf_extract(self, salt, ikm):  
    if salt is None or len(salt) == 0:  
        salt = b'\x00' * 32  
    return hmac.new(salt, ikm, hashlib.sha256).digest()  

def _hkdf_expand(self, prk, info, length):  
    t = b''  
    okm = b''  
    i = 1  
    while len(okm) < length:  
        t = hmac.new(prk, t + info + bytes([i]), hashlib.sha256).digest()  
        okm += t  
        i += 1  
    return okm[:length]  

def _hkdf_derive(self, salt, ikm, info, length):  
    prk = self._hkdf_extract(salt, ikm)  
    return self._hkdf_expand(prk, info, length)  

# --- Standard ChaCha20 (RFC 7539) Stream Cipher ---  
def _rotate_left(self, v, n):  
    return ((v << n) & 0xffffffff) | (v >> (32 - n))  

def _chacha20_quarter_round(self, state, a, b, c, d):  
    state[a] = (state[a] + state[b]) & 0xffffffff  
    state[d] = self._rotate_left(state[d] ^ state[a], 16)  
    state[c] = (state[c] + state[d]) & 0xffffffff  
    state[b] = self._rotate_left(state[b] ^ state[c], 12)  
    state[a] = (state[a] + state[b]) & 0xffffffff  
    state[d] = self._rotate_left(state[d] ^ state[a], 8)  
    state[c] = (state[c] + state[d]) & 0xffffffff  
    state[b] = self._rotate_left(state[b] ^ state[c], 7)  

def _chacha20_block(self, key, counter, nonce):  
    constants = [0x61707865, 0x3320646e, 0x79622d32, 0x6b206574] # "expand 32-byte k"  
    key_words = list(struct.unpack("<8I", key))  
    nonce_words = list(struct.unpack("<3I", nonce))  
    state = constants + key_words + [counter] + nonce_words  
    initial_state = list(state)  
      
    for _ in range(10): # 20 rounds  
        # Column round  
        self._chacha20_quarter_round(state, 0, 4, 8, 12)  
        self._chacha20_quarter_round(state, 1, 5, 9, 13)  
        self._chacha20_quarter_round(state, 2, 6, 10, 14)  
        self._chacha20_quarter_round(state, 3, 7, 11, 15)  
        # Diagonal round  
        self._chacha20_quarter_round(state, 0, 5, 10, 15)  
        self._chacha20_quarter_round(state, 1, 6, 11, 12)  
        self._chacha20_quarter_round(state, 2, 7, 8, 13)  
        self._chacha20_quarter_round(state, 3, 4, 9, 10)  
          
    out = [((state[i] + initial_state[i]) & 0xffffffff) for i in range(16)]  
    return struct.pack("<16I", *out)  

def _chacha20_encrypt_decrypt(self, key, nonce, plaintext, counter=1):  
    ciphertext = bytearray()  
    for i in range(0, len(plaintext), 64):  
        block = self._chacha20_block(key, counter, nonce)  
        chunk = plaintext[i:i+64]  
        for b, k in zip(chunk, block):  
            ciphertext.append(b ^ k)  
        counter += 1  
    return bytes(ciphertext)  

