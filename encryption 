def encrypt_data(self, data):  
    """  
    বিশুদ্ধ ও ক্রিপ্টোগ্রাফিকালি সুরক্ষিত চেইন এনক্রিপশন (ChaCha20 + HMAC-SHA256 with HKDF):  
    ১. সিরিয়ালাইজেশন: JSON ফরম্যাট  
    ২. সিকিউর র্যান্ডম ননস (12-byte) ও সল্ট (16-byte) তৈরি  
    ৩. HKDF-SHA256 দিয়ে আলাদা এনক্রিপশন ও ম্যাক কী তৈরি  
    ৪. ChaCha20 দিয়ে মেসেজ এনক্রিপশন  
    ৫. ডিক্রিপশন অথেন্টিকেশন এর জন্য HMAC-SHA256 জেনারেশন (Encrypt-then-MAC)  
    ৬. সুরক্ষিত প্যাকেজিং: magic (3B) + kid (2B) + salt (16B) + nonce (12B) + timestamp (8B) + tag (32B) + ciphertext  
    """  
    serialized = json.dumps(data)  
    payload_bytes = serialized.encode('utf-8')  
      
    # ২. ক্রিপ্টোগ্রাফিক র্যান্ডম ননস এবং সল্ট  
    salt = os.urandom(16)  
    nonce = os.urandom(12)  
      
    # টাইমস্ট্যাম্প (8-বাইটের বিগ-এন্ডিয়ান মিলিসেকেন্ড)  
    timestamp_ms = int(time.time() * 1000)  
    timestamp_bytes = struct.pack(">Q", timestamp_ms)  
      
    # ৩. HKDF কী ডেরিভেশন  
    master_key = self._keys[self._active_version]  
    enc_key = self._hkdf_derive(salt, master_key, b"Akira_ChaCha20_Encryption", 32)  
    mac_key = self._hkdf_derive(salt, master_key, b"Akira_HMAC_SHA256_Authentication", 32)  
      
    # ৪. ChaCha20 এনক্রিপশন  
    ciphertext = self._chacha20_encrypt_decrypt(enc_key, nonce, payload_bytes)  
      
    # ৫. HMAC-SHA256 অথেন্টিকেশন ট্যাগ তৈরি  
    magic = b'AKR'  
    kid_bytes = struct.pack(">H", self._active_version)  
      
    # MAC computes over entire envelope prefix and ciphertext  
    mac_payload = magic + kid_bytes + salt + nonce + timestamp_bytes + ciphertext  
    auth_tag = hmac.new(mac_key, mac_payload, hashlib.sha256).digest()  
      
    # 六. প্যাকেজিং  
    envelope = magic + kid_bytes + salt + nonce + timestamp_bytes + auth_tag + ciphertext  
    return base64.b64encode(envelope).decode('utf-8')  

def decrypt_data(self, encrypted_b64):  
    """  
    সার্বভৌম ডিক্রিপশন এবং কঠোর ভ্যালিডেশন লেয়ার:  
    ১. খাম ভাঙা এবং সাইজ চেক  
    ২. কি আইডি (kid) অনুযায়ী সঠিক কী রিট্রিভ করা  
    ৩. HKDF দিয়ে এনক্রিপশন ও ম্যাক কী পুনরায় তৈরি  
    ৪. কনস্ট্যান্ট-টাইম কম্পারিজনের মাধ্যমে HMAC ট্যাগ ম্যাচ করানো (Timing attack প্রতিরোধ)  
    ৫. টাইমস্ট্যাম্প ও ননস রিপ্লে অ্যাটাক চেক (Sliding Window Dedup)  
    ৬. ChaCha20 ডিক্রিপশন এবং JSON রিস্টোর  
    """  
    self._cleanup_nonce_cache()  
      
    try:  
        raw_bytes = base64.b64decode(encrypted_b64)  
          
        # নুন্যতম সাইজ চেক: magic (3B) + kid (2B) + salt (16B) + nonce (12B) + ts (8B) + hmac (32B) = 73 bytes  
        if len(raw_bytes) < 73:  
            raise ValueError("ক্রিপ্টোগ্রাফিক খামটির সাইজ অত্যন্ত ছোট।")  
              
        # ১. খাম থেকে বিভিন্ন বাইট আলাদা করা  
        magic = raw_bytes[:3]  
        if magic != b'AKR':  
            raise ValueError("অপরিচিত প্রোটোকল সিগনেচার।")  
              
        kid = struct.unpack(">H", raw_bytes[3:5])[0]  
        salt = raw_bytes[5:21]  
        nonce = raw_bytes[21:33]  
        timestamp_bytes = raw_bytes[33:41]  
        received_tag = raw_bytes[41:73]  
        ciphertext = raw_bytes[73:]  
          
        timestamp_ms = struct.unpack(">Q", timestamp_bytes)[0]  
          
        # ২. সঠিক কী রিট্রিভ করা  
        if kid not in self._keys:  
            raise PermissionError(f"অপরিচিত বা মেয়াদোত্তীর্ণ কী সংস্করণ: v{kid}")  
        master_key = self._keys[kid]  
          
        # ৩. কী পুনরায় ডেরিভেশন  
        enc_key = self._hkdf_derive(salt, master_key, b"Akira_ChaCha20_Encryption", 32)  
        mac_key = self._hkdf_derive(salt, master_key, b"Akira_HMAC_SHA256_Authentication", 32)  
          
        # ৪. HMAC অথেন্টিকেশন যাচাইকরণ (Encrypt-then-MAC)  
        mac_payload = magic + raw_bytes[3:5] + salt + nonce + timestamp_bytes + ciphertext  
        expected_tag = hmac.new(mac_key, mac_payload, hashlib.sha256).digest()  
          
        if not hmac.compare_digest(received_tag, expected_tag):  
            logger.warning(f"🚨 TAMPERING DETECTED: Authentication tag failed for Node {self.node_id}!")  
            raise PermissionError("🔒 ক্রিপ্টোগ্রাফিক সিগনেচার মেলেনি! ডেটা মাঝপথে পরিবর্তন করা হয়েছে।")  
              
        # ৫. রিপ্লে প্রোটেকশন এবং টাইমস্ট্যাম্প বৈধতা যাচাইকরণ  
        current_ms = int(time.time() * 1000)  
        drift = abs(current_ms - timestamp_ms)  
          
        if drift > self._drift_limit_ms:  
            logger.warning(f"🚨 TIMEOUT REJECTION: Request drift of {drift} ms exceeds the allowed window.")  
            raise PermissionError("⚠️ Replay protection error: Message timestamp is expired or out-of-sync.")  
              
        # ননস ডুপ্লিকেট চেক (Replay Attack)  
        nonce_hex = nonce.hex()  
        if nonce_hex in self._nonce_cache:  
            logger.warning(f"🚨 REPLAY ATTACK BLOCKED: Nonce {nonce_hex} reuse detected!")  
            raise PermissionError("⚠️ Replay Attack detected! This payload has already been processed.")  
              
        # ননস ক্যাশ করা  
        self._nonce_cache[nonce_hex] = timestamp_ms + self._drift_limit_ms  
          
        # ৬. ChaCha20 ডিক্রিপশন  
        decrypted_bytes = self._chacha20_encrypt_decrypt(enc_key, nonce, ciphertext)  
          
        # ৭. অবজেক্ট রিস্টোর  
        payload_data = json.loads(decrypted_bytes.decode('utf-8'))  
        return payload_data  
          
    except Exception as e:  
        logger.error(f"❌ Decryption Failed: {str(e)}")  
        raise ValueError(f"ডিক্রিপশন ব্যর্থ হয়েছে: {str(e)}")

